{
  "name": "@jamashita/dango",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git@github.com:jamashita/dango.git"
  },
  "license": "MIT",
  "author": "jamashita <jamashita@arachnid.xyz>",
  "type": "module",
  "scripts": {
    "build": "yarn clean && next build",
    "clean": "rimraf out && rimraf .next",
    "dev": "next dev",
    "format": "next lint",
    "prepare": "is-ci || husky install",
    "start": "next start",
    "test": "vitest",
    "update": "yarn update:upgrade && yarn update:install",
    "update:install": "yarn install && yarn upgrade && yarn audit fix --force",
    "update:upgrade": "ncu --packageManager yarn --deep --upgrade"
  },
  "dependencies": {
    "next": "16.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@typescript-eslint/typescript-estree": "8.58.1",
    "autoprefixer": "10.4.27",
    "eslint": "10.2.0",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "lint-staged": "16.4.0",
    "npm-check-updates": "20.0.0",
    "postcss": "8.5.9",
    "rimraf": "6.1.3",
    "sort-package-json": "3.6.1",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
